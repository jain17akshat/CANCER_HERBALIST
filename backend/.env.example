# ─────────────────────────────────────────────────────────────
# BACKEND .env.example — Copy this to .env and fill in values.
# ─────────────────────────────────────────────────────────────

# ── Supabase (persistent cloud storage) ────────────────────────
# Get from: Supabase project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # use service_role key

# Razorpay API credentials (from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Google Apps Script webhook for order recording (optional — keeps a Sheets backup)
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Shiprocket API credentials (create API user at: Shiprocket → Settings → API → Configure)
SHIPROCKET_EMAIL=your_shiprocket_api_user@example.com
SHIPROCKET_PASSWORD=your_shiprocket_api_password

# Allowed frontend origin for CORS
FRONTEND_URL=https://your-frontend.vercel.app

# Server port (local development only)
PORT=5001
# const SPREADSHEET_ID = "1dfGA_WunqNH3cIpghIbBuIR42p4KXba_EVIac_9mH4c";

# ─── Zoho CRM (India data center — zoho.in) ───────────────────────────────
# Get these from: https://api-console.zoho.in → Self Client
# Scopes needed: ZohoCRM.modules.contacts.ALL,ZohoCRM.modules.deals.ALL
ZOHO_CLIENT_ID=1000.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZOHO_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZOHO_REFRESH_TOKEN=1000.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Gmail SMTP for order confirmation emails ──────────────────────────────
# Use a Gmail App Password (NOT your regular password).
# Steps: Google Account → Security → 2-Step Verification → App Passwords
#   → Create app password for "Mail" → paste the 16-char code below.
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Admin email to receive new order notifications
ADMIN_EMAIL=your_admin@gmail.com

# ─── Zoho Books (India data center — zohoapis.in) ─────────────────────────
ZOHO_BOOKS_ORGANIZATION_ID=60067557891

# ─── Rate Limiting & Auth Backoff Configurations ─────────────────────────
RATE_LIMIT_WINDOW_MS=900000            # 15 minutes (in milliseconds)
RATE_LIMIT_MAX_PUBLIC=500             # Max requests per window on public endpoints
RATE_LIMIT_MAX_CHECKOUT=10            # Max order submissions per window
RATE_LIMIT_MAX_ADMIN=1000             # Max admin actions per window
RATE_LIMIT_MAX_AUTH_FAILURES=5        # Max consecutive failures before backoff
AUTH_LIMIT_BASE_COOLDOWN_MS=5000      # Initial backoff lockout time (5 seconds)
AUTH_LIMIT_MAX_COOLDOWN_MS=1800000    # Maximum backoff lockout time (30 minutes)
AUTH_LIMIT_WINDOW_MS=86400000         # Failure history reset window (24 hours)
