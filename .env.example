# ─────────────────────────────────────────────────────────────
# FRONTEND .env.example — Copy this to .env and fill in values.
# All VITE_* variables are bundled into client-side JavaScript
# and are publicly visible in the browser. Never put secrets here.
# ─────────────────────────────────────────────────────────────

# EmailJS (https://dashboard.emailjs.com)
VITE_EMAILJS_SERVICE_ID=service_XXXXXXX
VITE_EMAILJS_ADMIN_TEMPLATE_ID=template_XXXXXXX
VITE_EMAILJS_PATIENT_TEMPLATE_ID=template_XXXXXXX
VITE_EMAILJS_PUBLIC_KEY=XXXXXXXXXXXXXXXX

# Web3Forms (https://web3forms.com)
VITE_WEB3FORMS_KEY=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# Google Apps Script webhook URL
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# UPI ID displayed on the payment page
VITE_UPI_ID=yourupi@bank

# Backend API URL — NO trailing slash
VITE_BACKEND_URL=https://your-backend.vercel.app
